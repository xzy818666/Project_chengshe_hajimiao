merit_bank.app/Contents/PkgInfo: 
	@test -d merit_bank.app/Contents || mkdir -p merit_bank.app/Contents
	@$(DEL_FILE) merit_bank.app/Contents/PkgInfo
	@echo "APPL????" > merit_bank.app/Contents/PkgInfo
merit_bank.app/Contents/Info.plist: 
	@test -d merit_bank.app/Contents || mkdir -p merit_bank.app/Contents
	@$(DEL_FILE) merit_bank.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - ../../Qt/6.11.0/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.merit-bank,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.merit-bank,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,merit_bank,g" -e "s,@LIBRARY@,merit_bank,g" -e "s,\$${EXECUTABLE_NAME},merit_bank,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >merit_bank.app/Contents/Info.plist

