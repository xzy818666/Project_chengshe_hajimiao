####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/merit_bank/bin || mkdir -p $(INSTALL_ROOT)/opt/merit_bank/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/merit_bank/bin/merit_bank.app
	
	$(QINSTALL) merit_bank.app $(INSTALL_ROOT)/opt/merit_bank/bin/merit_bank.app
	-$(STRIP) $(INSTALL_ROOT)/opt/merit_bank/bin/merit_bank.app/Contents/MacOS/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/merit_bank/bin/merit_bank.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/merit_bank/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

.SUFFIXES:

